# Supabase — copy to .env.local and fill in from your project dashboard.
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth (login + /signup/staff): no extra env vars. In Supabase → Authentication → URL
# configuration, set Site URL (e.g. http://localhost:3000) and add Redirect URLs:
# http://localhost:3000/login and your production /login.

# Optional but recommended for MVP: server-only key bypasses RLS for admin reads and for
# server actions like confirmar entrega (insert em deliveries / update em registrations)
# when políticas RLS bloqueiam a anon key.
# Project Settings → API → service_role (never commit real values; use .env.local only).
SUPABASE_SERVICE_ROLE_KEY=
